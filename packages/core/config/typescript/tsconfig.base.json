{
	"compilerOptions": {
		"target": "ES2022",
		"jsx": "react-jsx",
		"useDefineForClassFields": true,
		"lib": ["ES2023", "ESNext.Disposable", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"rootDir": "../../../../",
		"skipLibCheck": true,
		"allowJs": false,
		"moduleResolution": "bundler",
		"paths": {
			"@strawdev/poppet-config": ["../../../../packages/core/config"],
			"@strawdev/poppet-config/*": ["../../../../packages/core/config/*"],
			"@strawdev/auth-client": ["../../../../packages/clients/auth-client/src/index.ts"],
			"@strawdev/contracts": ["../../../../packages/core/contracts/src/index.ts"],
			"@strawdev/contracts/*": ["../../../../packages/core/contracts/src/*"],
			"@strawdev/db-utils": ["../../../../packages/core/db-utils/src/index.ts"],
			"@strawdev/locale": ["../../../../packages/core/locale/src/index.ts"],
			"@strawdev/locale/*": ["../../../../packages/core/locale/src/*"],
			"@strawdev/smoke-testing": ["../../../../packages/testing/smoke/src/index.ts"],
			"@strawdev/app-client": ["../../../../packages/clients/app-client/src/index.ts"],
			"@strawdev/ui": ["../../../../packages/ui/src/index.ts"]
		},
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"moduleDetection": "force",
		"noEmit": true,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedSideEffectImports": true
	}
}
