# Poppet production runtime environment template.
# Values here are placeholders for a future production host.

POPPET_ENV=prod
POPPET_API_HOST=api.poppet.example
POPPET_WEB_HOSTS=poppet.example,www.poppet.example
POPPET_WEB_CANONICAL_HOST=poppet.example
POPPET_WEB_REDIRECT_HOSTS=www.poppet.example
POPPET_WEB_ROOT=/opt/poppet/prod/web
NODE_ENV=production

API_PORT=6201
API_ALLOWED_ORIGINS=https://poppet.example,https://www.poppet.example
AUTH_ALLOWED_ORIGINS=https://poppet.example,https://www.poppet.example
AUTH_BASE_URL=https://api.poppet.example
AUTH_JWT_AUDIENCE=poppet-prod
BETTER_AUTH_SECRET=

POSTGRES_PASSWORD=
DATABASE_URL=postgres://postgres:replace-me@poppet-postgres:5432/poppet_app

ELECTRIC_URL=http://poppet-electric:3000
ELECTRIC_SECRET=

VALKEY_URL=redis://poppet-valkey:6379

MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

MEILI_MASTER_KEY=

POPPET_RUNTIME_ENV_FILE=env/prod.env
