# Poppet local runtime environment template.
# Host-facing URLs use the 6200 port family.

POPPET_ENV=local
NODE_ENV=development

API_PORT=6201
API_ALLOWED_ORIGINS=http://localhost:6200
AUTH_ALLOWED_ORIGINS=http://localhost:6200
AUTH_BASE_URL=http://localhost:6201
AUTH_JWT_AUDIENCE=poppet-local
BETTER_AUTH_SECRET=replace-with-a-long-local-secret

POSTGRES_PASSWORD=password
DATABASE_URL=postgres://postgres:password@localhost:6202/poppet_app

ELECTRIC_URL=http://localhost:6203
ELECTRIC_SECRET=local-electric-secret

VALKEY_URL=redis://localhost:6204

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio-password

MEILI_MASTER_KEY=local-meili-secret

POPPET_RUNTIME_ENV_FILE=env/local.env
