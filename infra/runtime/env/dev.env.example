# Poppet remote-development runtime environment template.
# Values here are placeholders for a future remote dev host.

POPPET_ENV=dev
POPPET_API_HOST=api.dev.poppet.example
POPPET_WEB_HOSTS=dev.poppet.example
POPPET_WEB_ROOT=/opt/poppet/dev/web
NODE_ENV=production

API_PORT=6201
API_ALLOWED_ORIGINS=https://dev.poppet.example
AUTH_ALLOWED_ORIGINS=https://dev.poppet.example
AUTH_BASE_URL=https://api.dev.poppet.example
AUTH_JWT_AUDIENCE=poppet-dev
BETTER_AUTH_SECRET=

POSTGRES_PASSWORD=
DATABASE_URL=postgres://postgres:replace-me@poppet-postgres:5432/poppet_app

ELECTRIC_URL=http://poppet-electric:3000
ELECTRIC_SECRET=

VALKEY_URL=redis://poppet-valkey:6379

MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

MEILI_MASTER_KEY=

POPPET_RUNTIME_ENV_FILE=env/dev.env
