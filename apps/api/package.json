{
	"name": "@strawdev/api",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/router.ts"
	},
	"scripts": {
		"build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --target=node22 --packages=external",
		"db:generate": "node scripts/with-local-env.mjs drizzle-kit generate",
		"db:migrate": "node scripts/with-local-env.mjs drizzle-kit migrate",
		"dev": "node scripts/with-local-env.mjs node --import tsx --watch src/index.ts",
		"start": "node dist/index.js",
		"test": "vitest --run --passWithNoTests",
		"typecheck": "tsgo --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"@electric-sql/client": "1.5.20",
		"@strawdev/contracts": "workspace:*",
		"better-auth": "~1.6.11",
		"drizzle-orm": "^0.45.2",
		"nanoid": "^5.1.11",
		"pg": "^8.21.0",
		"redis": "^5.12.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@strawdev/poppet-config": "workspace:*",
		"@types/pg": "^8.20.0",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.22.3"
	}
}
